{
  "isolation": "worktree",
  "defaultMode": "interactive",
  "maxIterationsPerTask": 3,
  "maxIterationsGlobal": 30,
  "maxRetriesBeforeReset": 1,
  "phases": {
    "planner": {
      "prompt": "Optional override of the planner system prompt. If omitted, the workflow's default is used.",
      "allowedTools": [
        "Read",
        "Glob",
        "Grep",
        "WebSearch",
        "WebFetch",
        "Skill",
        "ToolSearch",
        "AskUserQuestion"
      ],
      "permissionMode": "bypassPermissions",
      "maxTurns": 50,
      "effort": "high",
      "model": "sonnet"
    },
    "developer": {
      "allowedTools": [
        "Read",
        "Edit",
        "Write",
        "Glob",
        "Grep",
        "Bash",
        "Skill",
        "ToolSearch"
      ],
      "permissionMode": "bypassPermissions",
      "maxTurns": 200,
      "effort": "high",
      "mcpServers": {
        "playwright": {
          "command": "npx",
          "args": ["@playwright/mcp@latest"]
        }
      }
    },
    "validator": {
      "allowedTools": ["Read", "Glob", "Grep", "Bash", "WebFetch"],
      "permissionMode": "bypassPermissions",
      "maxTurns": 200,
      "effort": "high"
    },
    "triage": {
      "allowedTools": ["Bash", "Read", "WebFetch", "Grep", "Glob"],
      "permissionMode": "bypassPermissions",
      "maxTurns": 50,
      "effort": "high"
    }
  }
}
